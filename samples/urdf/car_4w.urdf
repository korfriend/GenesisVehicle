<?xml version="1.0"?>
<!--
  car_4w.urdf — minimal 4-wheel car for genesis_vehicle SDK samples.

  Purpose
    Self-contained URDF (only primitive geometry, no external meshes) so
    `samples/*.py` work after a fresh `pip install genesis-vehicle` without
    bringing extra asset files. Compatible with the bundled
    `car_4w_rwd_ackermann` / `car_4w_fwd_ackermann` / `car_4w_awd_ackermann`
    presets.

  Project conventions implemented here
    - Steer joint axis: <axis xyz="0 0 -1"/>      (physics-contracts §7.4)
    - Wheel order in parser: FL, FR, RL, RR
    - Chassis collision box BOTTOM (z=0.60) is well above the wheel ray
      origin (z=0.30) so the downward raycast hits the ground, not the
      chassis itself (avoids "vehicle launches into sky" bug class)
    - Wheel links: visual-only (no <collision>). Contact forces come from
      the raycast pipeline, not from the rigid solver's wheel collision.

  Dimensions (typical sedan)
    Mass        1200 kg
    Wheelbase   2.7 m   (front axle x=+1.35, rear x=-1.35)
    Track       1.5 m   (left wheels y=+0.75, right y=-0.75)
    Wheel       radius 0.358 m, width 0.20 m
                (matches the physics radius in `car_4w_rwd_ackermann`'s wheel
                overrides; a smaller visual wheel would float above the ground)
-->
<robot name="car_4w">

  <!-- ===================== CHASSIS ===================== -->
  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0.5" rpy="0 0 0"/>
      <mass value="1200.0"/>
      <inertia ixx="450.0" iyy="2200.0" izz="2400.0" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <!-- Body visual: simple sedan box for chase-cam orientation. -->
    <visual>
      <origin xyz="0 0 0.7" rpy="0 0 0"/>
      <geometry><box size="4.3 1.7 0.5"/></geometry>
      <material name="body_red"><color rgba="0.7 0.15 0.15 1.0"/></material>
    </visual>
    <!-- Cabin: smaller box on top for forward/rear visual asymmetry. -->
    <visual>
      <origin xyz="-0.2 0 1.05" rpy="0 0 0"/>
      <geometry><box size="2.3 1.5 0.5"/></geometry>
      <material name="cabin_dark"><color rgba="0.2 0.2 0.25 1.0"/></material>
    </visual>
    <!-- Collision box: bottom at z=0.60, well above wheel ray origin z=0.30. -->
    <collision>
      <origin xyz="0 0 0.85" rpy="0 0 0"/>
      <geometry><box size="4.3 1.7 0.5"/></geometry>
    </collision>
  </link>

  <!-- ============== FRONT AXLE (x = +1.35, STEERED) ============== -->

  <!-- FL -->
  <joint name="front_left_suspension_joint" type="prismatic">
    <parent link="base_link"/><child link="front_left_axle_carrier"/>
    <origin xyz="1.35 0.75 0.30"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.15" upper="0.15" effort="0" velocity="10.0"/>
    <dynamics damping="0.0" friction="0.0" stiffness="0.0"/>
  </joint>
  <link name="front_left_axle_carrier">
    <inertial><origin xyz="0 0 0"/><mass value="10.0"/>
      <inertia ixx="0.1" iyy="0.1" izz="0.1" ixy="0" ixz="0" iyz="0"/></inertial>
  </link>
  <joint name="front_left_steer_joint" type="revolute">
    <parent link="front_left_axle_carrier"/><child link="front_left_steer_link"/>
    <origin xyz="0 0 0"/>
    <axis xyz="0 0 -1"/>   <!-- project standard: +steer → +joint_angle -->
    <limit lower="-0.7" upper="0.7" effort="500000.0" velocity="10.0"/>
    <dynamics damping="20.0" friction="0.0"/>
  </joint>
  <link name="front_left_steer_link">
    <inertial><origin xyz="0 0 0"/><mass value="5.0"/>
      <inertia ixx="0.05" iyy="0.05" izz="0.05" ixy="0" ixz="0" iyz="0"/></inertial>
  </link>
  <joint name="front_left_wheel_joint" type="continuous">
    <parent link="front_left_steer_link"/><child link="front_left_wheel"/>
    <origin xyz="0 0 0"/>
    <axis xyz="0 1 0"/>    <!-- spin axis: chassis +Y (left) -->
    <limit effort="0" velocity="200"/>
    <dynamics damping="0.1" friction="0.0"/>
  </joint>
  <link name="front_left_wheel">
    <inertial><origin xyz="0 0 0"/><mass value="20.0"/>
      <inertia ixx="1.0" iyy="2.0" izz="1.0" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.358" length="0.20"/></geometry>
      <material name="wheel_dark"><color rgba="0.10 0.10 0.10 1.0"/></material>
    </visual>
  </link>

  <!-- FR -->
  <joint name="front_right_suspension_joint" type="prismatic">
    <parent link="base_link"/><child link="front_right_axle_carrier"/>
    <origin xyz="1.35 -0.75 0.30"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.15" upper="0.15" effort="0" velocity="10.0"/>
    <dynamics damping="0.0" friction="0.0" stiffness="0.0"/>
  </joint>
  <link name="front_right_axle_carrier">
    <inertial><origin xyz="0 0 0"/><mass value="10.0"/>
      <inertia ixx="0.1" iyy="0.1" izz="0.1" ixy="0" ixz="0" iyz="0"/></inertial>
  </link>
  <joint name="front_right_steer_joint" type="revolute">
    <parent link="front_right_axle_carrier"/><child link="front_right_steer_link"/>
    <origin xyz="0 0 0"/>
    <axis xyz="0 0 -1"/>
    <limit lower="-0.7" upper="0.7" effort="500000.0" velocity="10.0"/>
    <dynamics damping="20.0" friction="0.0"/>
  </joint>
  <link name="front_right_steer_link">
    <inertial><origin xyz="0 0 0"/><mass value="5.0"/>
      <inertia ixx="0.05" iyy="0.05" izz="0.05" ixy="0" ixz="0" iyz="0"/></inertial>
  </link>
  <joint name="front_right_wheel_joint" type="continuous">
    <parent link="front_right_steer_link"/><child link="front_right_wheel"/>
    <origin xyz="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="0" velocity="200"/>
    <dynamics damping="0.1" friction="0.0"/>
  </joint>
  <link name="front_right_wheel">
    <inertial><origin xyz="0 0 0"/><mass value="20.0"/>
      <inertia ixx="1.0" iyy="2.0" izz="1.0" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.358" length="0.20"/></geometry>
      <material name="wheel_dark"><color rgba="0.10 0.10 0.10 1.0"/></material>
    </visual>
  </link>

  <!-- ============== REAR AXLE (x = -1.35, NON-STEERED) ============== -->

  <!-- RL -->
  <joint name="rear_left_suspension_joint" type="prismatic">
    <parent link="base_link"/><child link="rear_left_axle_carrier"/>
    <origin xyz="-1.35 0.75 0.30"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.15" upper="0.15" effort="0" velocity="10.0"/>
    <dynamics damping="0.0" friction="0.0" stiffness="0.0"/>
  </joint>
  <link name="rear_left_axle_carrier">
    <inertial><origin xyz="0 0 0"/><mass value="10.0"/>
      <inertia ixx="0.1" iyy="0.1" izz="0.1" ixy="0" ixz="0" iyz="0"/></inertial>
  </link>
  <joint name="rear_left_wheel_joint" type="continuous">
    <parent link="rear_left_axle_carrier"/><child link="rear_left_wheel"/>
    <origin xyz="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="0" velocity="200"/>
    <dynamics damping="0.1" friction="0.0"/>
  </joint>
  <link name="rear_left_wheel">
    <inertial><origin xyz="0 0 0"/><mass value="20.0"/>
      <inertia ixx="1.0" iyy="2.0" izz="1.0" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.358" length="0.20"/></geometry>
      <material name="wheel_dark"><color rgba="0.10 0.10 0.10 1.0"/></material>
    </visual>
  </link>

  <!-- RR -->
  <joint name="rear_right_suspension_joint" type="prismatic">
    <parent link="base_link"/><child link="rear_right_axle_carrier"/>
    <origin xyz="-1.35 -0.75 0.30"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.15" upper="0.15" effort="0" velocity="10.0"/>
    <dynamics damping="0.0" friction="0.0" stiffness="0.0"/>
  </joint>
  <link name="rear_right_axle_carrier">
    <inertial><origin xyz="0 0 0"/><mass value="10.0"/>
      <inertia ixx="0.1" iyy="0.1" izz="0.1" ixy="0" ixz="0" iyz="0"/></inertial>
  </link>
  <joint name="rear_right_wheel_joint" type="continuous">
    <parent link="rear_right_axle_carrier"/><child link="rear_right_wheel"/>
    <origin xyz="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="0" velocity="200"/>
    <dynamics damping="0.1" friction="0.0"/>
  </joint>
  <link name="rear_right_wheel">
    <inertial><origin xyz="0 0 0"/><mass value="20.0"/>
      <inertia ixx="1.0" iyy="2.0" izz="1.0" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.358" length="0.20"/></geometry>
      <material name="wheel_dark"><color rgba="0.10 0.10 0.10 1.0"/></material>
    </visual>
  </link>

</robot>
