<?xml version="1.0"?>
<!--
  car_raywheel.urdf
  =================
  Phase 2 ray-wheel paradigm용 URDF.

  변경 사항 (vs blender_car_suspension_pro.urdf 원본):
    1. 4개 wheel link <collision> 제거 (visual only)  → ray-wheel 방식
    2. 4개 suspension joint: prismatic → fixed (Genesis 시뮬에서 빠짐, 우리 코드에서 가상 구현)
    3. base_link <collision> 유지 (chassis는 충돌 ON)
    4. 2개 steer joint (front_left/right_steer_joint): revolute 유지 (앞바퀴 조향)
    5. 4개 wheel joint (front/rear_left/right_wheel_joint): continuous 유지 (visual mesh 회전용)
    6. mesh filename, mass, inertia 모두 동일

  구조 요약:
    - base_link (chassis, collision ON)
    - 4개 axle_carrier (suspension fixed로 매달림)
    - 2개 steer_link (front만, revolute joint)
    - 4개 wheel link (visual only, no collision)
-->
<robot name="car_raywheel">

  <!-- ===================== BASE LINK (Chassis) ===================== -->
  <link name="base_link">
    <inertial>
      <origin xyz="0.0 0 0.1" rpy="0 0 0"/>
      <mass value="2200.0"/>
      <inertia ixx="330.0" iyy="950.0" izz="1150.0" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <!-- visual only: physics에 영향 없음.
           z=0.32: body 바닥이 ground 위 ~10cm (sedan 클리어런스)
           y=-0.03: mesh 자체 y 비대칭 (-1.044 ~ +0.989, 중심이 -0.0275)을 보정 -->
      <origin xyz="0.10 0 0.40" rpy="0 0 0"/>
      <geometry>
        <mesh filename="pro_car_body.obj" scale="1 1 1"/>
      </geometry>
    </visual>
    <collision>
      <!-- chassis collision 유지 (외부 mesh와 충돌 가능, wheel만 OFF) -->
      <origin xyz="0 0 1.25" rpy="0 0 0"/>
      <geometry>
        <box size="4.63 0.5 0.6"/>
      </geometry>
    </collision>
  </link>

  <!-- ========================================================= -->
  <!-- FRONT LEFT SUSPENSION & STEER -->
  <!-- ========================================================= -->

  <!-- suspension joint: prismatic → fixed (가상 suspension은 코드에서 ray로 구현) -->
  <joint name="front_left_suspension_joint" type="prismatic">
    <parent link="base_link"/>
    <child link="front_left_axle_carrier"/>
    <!-- x=1.38: wheel mass/inertia 위치를 ray-cast 위치와 통일 -->
    <origin xyz="1.38 0.80 0.34" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.2" upper="0.2" effort="0" velocity="2.0"/>
    <!-- dynamics=0: Genesis 자체 spring/damper 비활성. 우리 ray-wheel만 적용. visual용 prismatic. -->
    <dynamics damping="0.0" friction="0.0" stiffness="0.0"/>
  </joint>

  <link name="front_left_axle_carrier">
    <inertial>
      <mass value="10.0"/>
      <inertia ixx="0.1" iyy="0.1" izz="0.1" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- steer joint: revolute 유지 (앞바퀴 조향) -->
  <joint name="front_left_steer_joint" type="revolute">
    <parent link="front_left_axle_carrier"/>
    <child link="front_left_steer_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 -1"/>
    <limit lower="-0.7" upper="0.7" effort="10000.0" velocity="4.0"/>
    <dynamics damping="10.0" friction="0.0"/>
  </joint>

  <link name="front_left_steer_link">
    <inertial>
      <mass value="5.0"/>
      <inertia ixx="0.1" iyy="0.1" izz="0.1" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- wheel joint: continuous 유지 (visual mesh 회전용; collision은 link <collision> 제거로 OFF) -->
  <joint name="front_left_wheel_joint" type="continuous">
    <parent link="front_left_steer_link"/>
    <child link="front_left_wheel"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="0" velocity="200"/>
    <dynamics damping="0.1" friction="0.0"/>
  </joint>

  <link name="front_left_wheel">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="20.0"/>
      <inertia ixx="1.174" iyy="2.348" izz="1.174" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <!-- wheel link이 이미 chassis local 1.38에 있어 visual offset 불필요. -->
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <mesh filename="pro_wheel_fl.obj" scale="1 1 1"/>
      </geometry>
    </visual>
    <!-- collision REMOVED (ray-wheel) -->
  </link>

  <!-- ========================================================= -->
  <!-- FRONT RIGHT SUSPENSION & STEER -->
  <!-- ========================================================= -->

  <joint name="front_right_suspension_joint" type="prismatic">
    <parent link="base_link"/>
    <child link="front_right_axle_carrier"/>
    <origin xyz="1.38 -0.80 0.34" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.2" upper="0.2" effort="0" velocity="2.0"/>
    <dynamics damping="0.0" friction="0.0" stiffness="0.0"/>
  </joint>

  <link name="front_right_axle_carrier">
    <inertial>
      <mass value="10.0"/>
      <inertia ixx="0.1" iyy="0.1" izz="0.1" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="front_right_steer_joint" type="revolute">
    <parent link="front_right_axle_carrier"/>
    <child link="front_right_steer_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 -1"/>
    <limit lower="-0.7" upper="0.7" effort="10000.0" velocity="4.0"/>
    <dynamics damping="10.0" friction="0.0"/>
  </joint>

  <link name="front_right_steer_link">
    <inertial>
      <mass value="5.0"/>
      <inertia ixx="0.1" iyy="0.1" izz="0.1" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="front_right_wheel_joint" type="continuous">
    <parent link="front_right_steer_link"/>
    <child link="front_right_wheel"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="0" velocity="200"/>
    <dynamics damping="0.1" friction="0.0"/>
  </joint>

  <link name="front_right_wheel">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="20.0"/>
      <inertia ixx="1.174" iyy="2.348" izz="1.174" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <!-- wheel link이 이미 chassis local 1.38에 있어 visual offset 불필요. -->
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <mesh filename="pro_wheel_fr.obj" scale="1 1 1"/>
      </geometry>
    </visual>
    <!-- collision REMOVED (ray-wheel) -->
  </link>

  <!-- ========================================================= -->
  <!-- REAR LEFT (Driven) -->
  <!-- ========================================================= -->

  <joint name="rear_left_suspension_joint" type="prismatic">
    <parent link="base_link"/>
    <child link="rear_left_axle_carrier"/>
    <origin xyz="-1.35 0.80 0.34" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.2" upper="0.2" effort="0" velocity="2.0"/>
    <dynamics damping="0.0" friction="0.0" stiffness="0.0"/>
  </joint>

  <link name="rear_left_axle_carrier">
    <inertial>
      <mass value="10.0"/>
      <inertia ixx="0.1" iyy="0.1" izz="0.1" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="rear_left_wheel_joint" type="continuous">
    <parent link="rear_left_axle_carrier"/>
    <child link="rear_left_wheel"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="100000" velocity="200"/>
    <dynamics damping="0.1" friction="0.0"/>
  </joint>

  <link name="rear_left_wheel">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="20.0"/>
      <inertia ixx="1.174" iyy="2.348" izz="1.174" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <mesh filename="pro_wheel_rl.obj" scale="1 1 1"/>
      </geometry>
    </visual>
    <!-- collision REMOVED (ray-wheel) -->
  </link>

  <!-- ========================================================= -->
  <!-- REAR RIGHT (Driven) -->
  <!-- ========================================================= -->

  <joint name="rear_right_suspension_joint" type="prismatic">
    <parent link="base_link"/>
    <child link="rear_right_axle_carrier"/>
    <origin xyz="-1.35 -0.80 0.34" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.2" upper="0.2" effort="0" velocity="2.0"/>
    <dynamics damping="0.0" friction="0.0" stiffness="0.0"/>
  </joint>

  <link name="rear_right_axle_carrier">
    <inertial>
      <mass value="10.0"/>
      <inertia ixx="0.1" iyy="0.1" izz="0.1" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="rear_right_wheel_joint" type="continuous">
    <parent link="rear_right_axle_carrier"/>
    <child link="rear_right_wheel"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="100000" velocity="200"/>
    <dynamics damping="0.1" friction="0.0"/>
  </joint>

  <link name="rear_right_wheel">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="20.0"/>
      <inertia ixx="1.174" iyy="2.348" izz="1.174" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <mesh filename="pro_wheel_rr.obj" scale="1 1 1"/>
      </geometry>
    </visual>
    <!-- collision REMOVED (ray-wheel) -->
  </link>

</robot>
